# ===========================================
# Valueskins - Premium Creator Credentials
# Americanized Configuration (USD Only)
# ===========================================

# ==== BACKEND DATABASE & SECURITY ====
DATABASE_URL=postgres://postgres:password@localhost:5432/valueskins
JWT_SECRET=your-secure-jwt-secret-min-32-chars
RUST_LOG=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://valueskins.app

# ==== API SECURITY (HMAC) ====
API_KEY_HMAC_SALT=your-secure-api-key-salt-min-32-chars
VERIFICATION_HMAC_SECRET=your-secure-verification-secret-min-32-chars
PLATFORM_SIGNING_KEY_ED25519=your-ed25519-signing-key-base64

# ==== MONITORING & METRICS ====
METRICS_BEARER_TOKEN=your-metrics-scrape-token-min-32-chars

# ==== EMAIL NOTIFICATIONS (USD BILLING) ====
SMTP_HOST=smtp.sendgrid.net
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=billing@valueskins.app

# ==== FRONTEND ====
NEXT_PUBLIC_API_URL=https://api.valueskins.app
NEXT_PUBLIC_APP_NAME=Valueskins
NEXT_PUBLIC_CURRENCY=USD

# ==== PRICING (USD ONLY) ====
# These are referenced in the UI
NEXT_PUBLIC_INTRO_PRICE=9.99
NEXT_PUBLIC_STANDARD_PRICE=19.99
NEXT_PUBLIC_PREMIUM_PRICE=49.99
NEXT_PUBLIC_TRIAL_DAYS=7

# ==== OAUTH INTEGRATIONS ====
# Instagram (Meta Graph API)
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://valueskins.app/auth/callback

# LinkedIn (LinkedIn API v2)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://valueskins.app/auth/linkedin/callback
LINKEDIN_API_BASE_URL=https://api.linkedin.com/v2
LINKEDIN_FEATURE_FLAG=true

# ==== PAYMENT PROCESSING (STRIPE - USD) ====
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==== AMERICAN BRANDING ====
NEXT_PUBLIC_COMPANY_NAME=Valueskins Inc.
NEXT_PUBLIC_BRAND_COLOR=#ffd700
NEXT_PUBLIC_ACCENT_COLOR=#c41e3a
NEXT_PUBLIC_SUPPORT_EMAIL=support@valueskins.app
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://valueskins.app/privacy
NEXT_PUBLIC_TERMS_URL=https://valueskins.app/terms
